---
import PageLayout from '../../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
---

<PageLayout title="Tentang LastBite" description="Pelajari cerita di balik LastBite — misi, tim, dan perjalanan kami." breadcrumb="Tentang LastBite">
  <!-- Hero -->
  <section class="max-w-md md:max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-flex items-center gap-2 bg-lastbite-green/10 text-lastbite-green text-xs font-semibold px-4 py-2 rounded-full mb-4 font-body">
          <Icon name="solar:leaf-bold" class="w-4 h-4" /> Startup Jember
        </span>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-5">
          Kami hadir untuk <span class="text-lastbite-green">mengurangi waste</span>, bukan menambahnya.
        </h1>
        <p class="font-body text-gray-500 text-base leading-relaxed mb-4">
          LastBite adalah platform lokal berbasis di Jember yang menghubungkan bisnis dengan stok berlebih kepada konsumen yang ingin berhemat — sambil sama-sama mengurangi limbah makanan dan barang.
        </p>
        <p class="font-body text-gray-500 text-base leading-relaxed">
          Kami percaya bahwa makanan yang baik dan produk berkualitas tidak seharusnya berakhir di tempat sampah hanya karena tanggal mendekati expiry atau stok tidak terjual.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {[
          { emoji: "🌱", title: "Misi Kami", desc: "Membangun ekosistem ekonomi melingkar (circular economy) di tingkat lokal Jember." },
          { emoji: "🤝", title: "Nilai Kami", desc: "Transparansi, komunitas, dan keberlanjutan lingkungan di setiap keputusan bisnis." },
          { emoji: "🏆", title: "Visi Kami", desc: "Menjadi platform #1 untuk rescue goods dan circular commerce di seluruh Indonesia." },
          { emoji: "💡", title: "Kenapa Jember?", desc: "Jember adalah kota dengan ekosistem kuliner dan UMKM yang kaya — tepat untuk mulai." },
        ].map(card => (
          <div class="bg-[#F7FBF7] rounded-[1.5rem] p-5 border border-green-100">
            <p class="text-2xl mb-3">{card.emoji}</p>
            <h3 class="font-heading font-bold text-gray-900 text-sm mb-2">{card.title}</h3>
            <p class="font-body text-xs text-gray-500 leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-lastbite-darkGreen py-16 text-center">
    <div class="max-w-md md:max-w-2xl mx-auto px-6">
      <h2 class="font-heading text-3xl font-bold text-white mb-3">Bergabung dalam Gerakan Ini</h2>
      <p class="font-body text-green-200 text-sm mb-8">Bersama-sama kita bisa membangun Jember yang lebih hemat dan lebih hijau.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/pengguna/dapatkan-aplikasi" class="inline-flex items-center gap-2 bg-white text-gray-900 font-semibold px-6 py-3.5 rounded-2xl hover:bg-gray-50 transition-colors text-sm">
          <Icon name="solar:smartphone-bold" class="w-4 h-4 text-lastbite-green" />
          Mulai Belanja
        </a>
        <a href="/mitra/jadi-penjual" class="inline-flex items-center gap-2 bg-lastbite-orange text-white font-semibold px-6 py-3.5 rounded-2xl hover:bg-orange-600 transition-colors text-sm">
          <Icon name="solar:shop-bold" class="w-4 h-4" />
          Jadi Mitra
        </a>
      </div>
    </div>
  </section>
</PageLayout>
