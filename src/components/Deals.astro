---
import { Icon } from 'astro-icon/components';

const deals = [
  {
    img: "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=600&q=80",
    badge: "Food",
    store: "Warung Bu Siti",
    name: "Paket Nasi Campur Spesial",
    originalPrice: "Rp 35.000",
    discountPrice: "Rp 14.000",
    discount: "60%",
    stock: 4,
    rating: 4.8,
  },
  {
    img: "https://images.unsplash.com/photo-1563636619-e9143da7973b?w=600&q=80",
    badge: "Minuman",
    store: "Kopi Jember",
    name: "Cold Brew 500ml Bundle",
    originalPrice: "Rp 55.000",
    discountPrice: "Rp 22.000",
    discount: "60%",
    stock: 2,
    rating: 4.9,
  },
  {
    img: "https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=600&q=80",
    badge: "Preloved",
    store: "Toko Zara Vintage",
    name: "Kaos Cotton Oversize Premium",
    originalPrice: "Rp 180.000",
    discountPrice: "Rp 60.000",
    discount: "67%",
    stock: 1,
    rating: 4.7,
  },
  {
    img: "https://images.unsplash.com/photo-1604382354936-07c5d9983bd3?w=600&q=80",
    badge: "Bakeri",
    store: "Breadbox Jember",
    name: "Mix Roti Artisan 6 pcs",
    originalPrice: "Rp 70.000",
    discountPrice: "Rp 28.000",
    discount: "60%",
    stock: 3,
    rating: 4.6,
  },
  {
    img: "https://images.unsplash.com/photo-1571091718767-18b5b1457add?w=600&q=80",
    badge: "Fast Food",
    store: "Burger Lokal JMR",
    name: "Burger Komplit + Kentang",
    originalPrice: "Rp 42.000",
    discountPrice: "Rp 18.000",
    discount: "57%",
    stock: 5,
    rating: 4.5,
  },
  {
    img: "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80",
    badge: "Kecantikan",
    store: "Beauty Corner",
    name: "Skincare Set (3 items)",
    originalPrice: "Rp 250.000",
    discountPrice: "Rp 85.000",
    discount: "66%",
    stock: 2,
    rating: 4.8,
  },
];
---

<section class="py-20 bg-[#F7FBF7]">
  <div class="max-w-md md:max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end mb-10 gap-4">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-gray-900 mb-2">
          Deal <span class="text-lastbite-orange">Terpanas</span> 🔥
        </h2>
        <p class="font-body text-gray-500 text-sm">Diperbarui setiap hari — jangan sampai kehabisan!</p>
      </div>
      <div class="flex items-center gap-2">
        <button id="deal-prev" class="w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-lastbite-green hover:text-white hover:border-lastbite-green transition-all">
          <Icon name="solar:arrow-left-linear" class="w-5 h-5" />
        </button>
        <button id="deal-next" class="w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-lastbite-green hover:text-white hover:border-lastbite-green transition-all">
          <Icon name="solar:arrow-right-linear" class="w-5 h-5" />
        </button>
      </div>
    </div>

    <!-- Carousel track -->
    <div class="overflow-hidden" id="deal-overflow">
      <div id="deal-track" class="flex gap-5 transition-transform duration-500 ease-in-out will-change-transform">
        {deals.map(deal => (
          <div class="deal-card flex-shrink-0 w-[280px] bg-white rounded-[2rem] overflow-hidden shadow-sm border border-gray-100 flex flex-col group cursor-pointer hover:shadow-md transition-shadow duration-300">
            <div class="relative overflow-hidden">
              <img
                src={deal.img}
                alt={deal.name}
                class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-gray-700 text-[10px] font-bold px-3 py-1 rounded-full">
                {deal.badge}
              </span>
              <span class="absolute top-3 right-3 bg-lastbite-orange text-white text-xs font-bold px-3 py-1 rounded-full">
                -{deal.discount}
              </span>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <p class="text-[10px] text-gray-400 font-body mb-1">{deal.store}</p>
              <h3 class="font-heading font-bold text-gray-900 text-sm leading-snug mb-3 line-clamp-2">{deal.name}</h3>
              <div class="flex items-center gap-1 mb-3">
                <Icon name="solar:star-bold" class="w-3.5 h-3.5 text-yellow-400" />
                <span class="text-xs font-semibold text-gray-700">{deal.rating}</span>
                <span class="text-[10px] text-gray-400 ml-1">· Sisa {deal.stock} lagi</span>
              </div>
              <div class="mt-auto flex items-end justify-between">
                <div>
                  <p class="text-[10px] text-gray-400 line-through font-body">{deal.originalPrice}</p>
                  <p class="font-heading font-bold text-lastbite-green text-lg leading-none">{deal.discountPrice}</p>
                </div>
                <button class="bg-lastbite-green text-white text-xs font-semibold px-4 py-2 rounded-xl hover:bg-green-700 transition-colors">
                  Ambil
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Dots indicator -->
    <div id="deal-dots" class="flex justify-center gap-2 mt-8">
    </div>
  </div>
</section>

<script>
  const track    = document.getElementById('deal-track')!;
  const prevBtn  = document.getElementById('deal-prev')!;
  const nextBtn  = document.getElementById('deal-next')!;
  const dotsEl   = document.getElementById('deal-dots')!;
  const cards    = document.querySelectorAll<HTMLElement>('.deal-card');
  const CARD_W   = 280 + 20; // width + gap
  const VISIBLE  = Math.floor(document.getElementById('deal-overflow')!.clientWidth / CARD_W) || 1;
  const MAX_IDX  = Math.max(0, cards.length - VISIBLE);

  let current = 0;
  let autoPlay: ReturnType<typeof setInterval>;

  // Build dots
  const totalDots = MAX_IDX + 1;
  for (let i = 0; i < totalDots; i++) {
    const dot = document.createElement('button');
    dot.className = 'deal-dot w-2 h-2 rounded-full bg-gray-300 transition-all duration-300';
    dot.addEventListener('click', () => goTo(i));
    dotsEl.appendChild(dot);
  }

  function goTo(idx: number) {
    current = Math.max(0, Math.min(idx, MAX_IDX));
    track.style.transform = `translateX(-${current * CARD_W}px)`;
    dotsEl.querySelectorAll<HTMLElement>('.deal-dot').forEach((d, i) => {
      if (i === current) {
        d.classList.remove('bg-gray-300', 'w-2');
        d.classList.add('bg-lastbite-green', 'w-6');
      } else {
        d.classList.add('bg-gray-300', 'w-2');
        d.classList.remove('bg-lastbite-green', 'w-6');
      }
    });
  }

  goTo(0);

  prevBtn.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
  nextBtn.addEventListener('click', () => { goTo(current + 1 > MAX_IDX ? 0 : current + 1); resetAuto(); });

  function startAuto() {
    autoPlay = setInterval(() => goTo(current + 1 > MAX_IDX ? 0 : current + 1), 3500);
  }
  function resetAuto() { clearInterval(autoPlay); startAuto(); }

  startAuto();
</script>
