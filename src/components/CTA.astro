---
import { Icon } from 'astro-icon/components';
---

<section class="py-20 px-6">
  <div class="max-w-md md:max-w-6xl mx-auto">
    <div class="bg-lastbite-darkGreen rounded-[3rem] px-8 md:px-16 py-14 md:py-20 relative overflow-hidden flex flex-col md:flex-row items-center gap-10 md:gap-16">
      
      <!-- Decorative blobs -->
      <div class="absolute -top-20 -right-20 w-72 h-72 bg-lastbite-green/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-10 w-56 h-56 bg-lastbite-orange/10 rounded-full blur-3xl pointer-events-none"></div>

      <div class="flex-1 relative z-10">
        <span class="inline-block text-xs font-semibold text-lastbite-green bg-lastbite-green/10 px-4 py-2 rounded-full mb-6 font-body">
          🌱 Bergabung Sekarang — Gratis!
        </span>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
          Mulai Hemat,<br/>Mulai <span class="text-lastbite-orange">Berkontribusi</span>.
        </h2>
        <p class="font-body text-green-200 text-sm md:text-base leading-relaxed max-w-md">
          Download aplikasinya sekarang dan dapatkan diskon pertamamu!
        </p>
      </div>

      <div class="relative z-10 flex flex-col gap-4 w-full md:w-auto">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5 backdrop-blur-sm">
          <p class="text-white font-heading font-bold mb-4 text-sm">Dapatkan Aplikasi</p>
          <div class="flex flex-col gap-3">
            <a href="/pengguna/dapatkan-aplikasi" class="flex items-center justify-center gap-3 bg-white text-gray-900 px-8 py-4 rounded-xl font-bold text-base hover:bg-gray-50 transition-all hover:scale-[1.02] group">
              <Icon name="solar:download-minimalistic-bold" class="w-6 h-6 text-lastbite-green group-hover:animate-bounce" />
              Dapatkan Aplikasi
              <Icon name="solar:arrow-right-linear" class="w-4 h-4 ml-auto text-gray-400 group-hover:translate-x-1 transition-transform" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
