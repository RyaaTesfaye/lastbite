---
import { Icon } from "astro-icon/components";
---

<footer
  class="bg-lastbite-darkGreen text-white pt-16 pb-8 px-8 mt-12 rounded-t-[3rem] md:rounded-t-[4rem]"
>
  <div
    class="max-w-md md:max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8"
  >
    <div class="md:col-span-1">
      <a href="/" class="inline-block mb-6 hover:opacity-80 transition-opacity">
        <img src="/logo.png" alt="LastBite Logo" class="h-20 w-auto" />
      </a>
      <p class="text-green-50 font-body text-sm leading-relaxed max-w-xs">
        Platform digital untuk mengurangi limbah, menghemat pengeluaran, dan
        membangun komunitas yang lebih berkelanjutan di area Jember.
      </p>
    </div>

    <div>
      <h4 class="font-heading font-bold text-lg mb-5">Pengguna</h4>
      <ul class="space-y-4 font-body text-green-100 text-sm">
        <li>
          <a
            href="/pengguna/dapatkan-aplikasi"
            class="hover:text-white transition-colors">Dapatkan Aplikasi</a>
        </li>
        <li>
          <a
            href="/pengguna/cara-membeli"
            class="hover:text-white transition-colors">Cara Membeli</a>
        </li>
        <li>
          <a
            href="/pengguna/kebijakan-refund"
            class="hover:text-white transition-colors">Kebijakan Refund</a>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-heading font-bold text-lg mb-5">Mitra</h4>
      <ul class="space-y-4 font-body text-green-100 text-sm">
        <li>
          <a
            href="/mitra/jadi-penjual"
            class="hover:text-white transition-colors">Jadi Penjual</a>
        </li>
        <li>
          <a
            href="/mitra/panduan-penjual"
            class="hover:text-white transition-colors">Panduan Penjual</a>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-heading font-bold text-lg mb-5">LastBite</h4>
      <ul class="space-y-4 font-body text-green-100 text-sm">
        <li>
          <a
            href="/tentang/tentang-lastbite"
            class="hover:text-white transition-colors">Tentang LastBite</a>
        </li>
        <li>
          <a
            href="/tentang/hubungi-kami"
            class="hover:text-white transition-colors">Hubungi Kami</a>
        </li>
        <li>
          <a
            href="/tentang/kebijakan-privasi"
            class="hover:text-white transition-colors">Kebijakan Privasi</a>
        </li>
      </ul>
    </div>
  </div>

  <div
    class="max-w-md md:max-w-6xl mx-auto mt-16 pt-8 border-t border-white/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-6"
  >
    <p class="font-body text-green-200 text-xs">
      © 2026 LastBite. Hak cipta dilindungi.
    </p>

    <div class="flex gap-5 text-green-200">
      <a
        href="https://www.instagram.com/by_lastbite/"
        target="_blank"
        class="hover:text-white transition-colors"
        aria-label="Instagram"
      >
        <Icon name="solar:camera-minimalistic-linear" class="w-5 h-5" />
      </a>
    </div>
  </div>
</footer>
